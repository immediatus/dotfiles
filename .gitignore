# ~/.dotfiles/.gitignore
# Ignore system and editor swap/temp files
*~
*.swp
*.tmp
.DS_Store

# Ignore credentials, API keys, tokens, and agent state
.env
.env.*
*.pem
*.key
*.token
.claude/
.claude.json
.gemini/
.ssh/
settings.json

# Ignore container state/logs
*.log

# Ignore runtime and cache directories in stow
stow/zsh/.local/share/
stow/zsh/.local/state/
stow/zellij/.config/zellij/config.kdl.bak*
*yazi_cmd_history

# Ignore cloneable Zsh plugins
stow/zsh/.zsh/plugins/zsh-autosuggestions/
stow/zsh/.zsh/plugins/zsh-syntax-highlighting/

# Ignore local shell override configurations
stow/zsh/.zshrc.local
stow/git/.gitconfig.local

# Ignore local GGUF models and runtime state files in models
models/*.gguf
models/*.bin
models/.active_env
models/.active_model
models/kv_cache_dump/




