#!/usr/bin/env bash
# ~/Sync/config/.local/bin/llama
set -e

# Manage the llama-rocm container service via systemd Quadlet and Podman

llama() {
  local BASE="/home/$USER/models"
  local STATE_FILE="$BASE/.active_model"
  local ENV_FILE="$BASE/.active_env"
  local CONFIG_FILE="$BASE/models.json"
  local SERVICE_NAME="llama-rocm" # Generates llama-rocm.service from Quadlet

  # Auto-initialize models.json if missing
  if [[ ! -f "$CONFIG_FILE" ]]; then
    cat <<EOF > "$CONFIG_FILE"
{
  "expert": {
    "file": "Qwen_Qwen3.5-122B-A10B-Q4_K_M-00001-of-00002.gguf",
    "args": "--fit off --no-mmap --n-gpu-layers 99 --ctx-size 262144 --parallel 1 --batch-size 2048 --ubatch-size 1024 --cache-type-k q4_0 --cache-type-v q4_0 --threads 8 --threads-batch 8 --flash-attn on --temp 1.0 --top-p 0.95 --top-k 40 --min-p 0.05 --repeat-last-n 512 --repeat-penalty 1.05"
  },
  "reson": {
    "file": "Qwen3.5-27B-Claude-4.6-Opus-Reasoning-Distilled-Q6_K.gguf",
    "args": "--ctx-size 131072 --parallel 1 --batch-size 2048 --ubatch-size 1024 --cache-type-k q8_0 --cache-type-v q4_0 --threads 8 --threads-batch 8 --flash-attn on --no-mmap --mlock --temp 1.0 --top-p 0.95 --top-k 40 --min-p 0.05 --repeat-last-n 256 --repeat-penalty 1.05"
  },
  "agent": {
    "file": "Qwen_Qwen3-Coder-Next-Q8_0-00001-of-00003.gguf",
    "args": "--ctx-size 131072 --parallel 1 --batch-size 2048 --ubatch-size 1024 --cache-type-k q8_0 --cache-type-v q4_0 --threads 8 --threads-batch 8 --flash-attn on --no-mmap --mlock --temp 1.0 --top-p 0.95 --top-k 40 --min-p 0.05 --repeat-last-n 256 --repeat-penalty 1.05"
  },
  "simple": {
    "file": "gemma-3-12b-it-Q4_K_M.gguf",
    "args": "-md /models/gemma-3-270m-it-Q8_0.gguf --draft-max 5 --draft-min 3 --ctx-size 131072 --parallel 8 --batch-size 2048 --ubatch-size 1024 --cache-type-k q8_0 --cache-type-v q8_0 --threads 8 --threads-batch 8 --flash-attn on --mlock --temp 0.7 --top-p 0.90 --top-k 40 --min-p 0.05 --repeat-last-n 512 --repeat-penalty 1.05"
  }
}
EOF
  fi


  case "$1" in
    setup)
      echo "=== Llama ROCm Service Setup ==="
      echo ""
      
      if ! command -v podman &>/dev/null; then
        echo "ERROR: podman is not installed or not in PATH"
        return 1
      fi
      
      echo "[1/4] Pulling official llama.cpp ROCm container image..."
      podman pull ghcr.io/ggml-org/llama.cpp:server-rocm
      
      echo "[2/4] Creating directories..."
      mkdir -p "$BASE/kv_cache_dump"
      
      # Initialize model state if missing
      if [[ ! -f "$ENV_FILE" ]]; then
        echo "      Initializing with 'expert' model configuration..."
        # Default to expert since it is already downloaded
        llama switch expert
      fi
      
      echo "[3/4] Activating systemd user service..."
      loginctl enable-linger "$USER" || true
      
      if ! systemctl --user daemon-reload; then
        echo "ERROR: Failed to reload systemd daemon"
        return 1
      fi
      

      
      echo "[4/4] Starting service..."
      if ! systemctl --user restart "$SERVICE_NAME"; then
        echo "WARNING: Service failed to start. Check logs with:"
        echo "  journalctl --user -u $SERVICE_NAME -n 50"
      else
        echo "      Service started successfully!"
      fi
      
      echo "=== Setup Complete ==="
      ;;

    switch)
      local model_type=$2
      local file="" args=""

      if [[ -z "$model_type" ]]; then
        echo "Usage: llama switch <profile>"
        echo ""
        echo "Available profiles in models.json:"
        python3 -c "import json; d=json.load(open('$CONFIG_FILE')); [print(f'  - {k} ({d[k].get(\"file\")})') for k in d]" 2>/dev/null || echo "  (failed to parse models.json)"
        echo ""
        echo "Current GGUF files in $BASE:"
        ls -1 "$BASE"/*.gguf 2>/dev/null | while read f; do
          local basename=$(basename "$f")
          echo "  - $basename"
        done || echo "  (none found)"
        return 1
      fi

      # Parse model file and parameters from models.json using Python
      file=$(python3 -c "import json, sys; print(json.load(open('$CONFIG_FILE')).get(sys.argv[1], {}).get('file', ''))" "$model_type" 2>/dev/null || echo "")
      args=$(python3 -c "import json, sys; print(json.load(open('$CONFIG_FILE')).get(sys.argv[1], {}).get('args', ''))" "$model_type" 2>/dev/null || echo "")

      if [[ -z "$file" ]]; then
        echo "ERROR: Unknown model profile: $model_type"
        echo "Usage: llama switch <profile>"
        return 1
      fi

      local model_path="$BASE/$file"
      if [[ ! -f "$model_path" ]]; then
        echo "ERROR: Model file not found: $model_path"
        echo "Please make sure the GGUF file is placed in $BASE."
        return 1
      fi

      # Write state for simple-state checks
      echo "$file" > "$STATE_FILE"
      
      # Write env file for systemd Quadlet service
      cat <<EOF > "$ENV_FILE"
ACTIVE_MODEL="/models/$file"
ACTIVE_ARGS="$args"
EOF
      
      echo "=== Model Switched ==="
      echo "  Type: $model_type"
      echo "  File: $file"
      
      if systemctl --user is-active --quiet "$SERVICE_NAME"; then
          echo ""
          echo "Service is running. Restarting to apply changes..."
          if systemctl --user restart "$SERVICE_NAME"; then
            echo "Service restarted successfully."
          else
            echo "ERROR: Failed to restart service."
            return 1
          fi
      else
          echo ""
          echo "Service is NOT running. Starting it now..."
          if systemctl --user start "$SERVICE_NAME"; then
            echo "Service started successfully."
          else
            echo "ERROR: Failed to start service."
            return 1
          fi
      fi
      ;;

    simple-state)
      if ! systemctl --user is-active -q "$SERVICE_NAME"; then
        echo "OFF"
      else
        local cur=$(cat "$STATE_FILE" 2>/dev/null)
        case "$cur" in
          *Reasoning*)  echo "REASON" ;;
          *Next*)       echo "AGENT"  ;;
          *122B*)       echo "EXPERT" ;;
          *12b*)        echo "SIMPLE" ;;
          *)            echo "ON"     ;;
        esac
      fi
      ;;

    status|start|stop|restart) 
      systemctl --user "$1" "$SERVICE_NAME" 
      ;;

    logs)
      journalctl --user -u "$SERVICE_NAME" -f
      ;;

    save)
      local filename=$2
      if [[ -z "$filename" ]]; then
        echo "Usage: llama save <filename>"
        return 1
      fi
      curl -s --request POST \
        --url "http://127.0.0.1:8080/slots/0?action=save" \
        --header "Content-Type: application/json" \
        --data '{ "filename": "'$filename'.bin" }'
      ;;

    load)
      local filename=$2
      if [[ -z "$filename" ]]; then
        echo "Usage: llama load <filename>"
        return 1
      fi
      local bin_file="${filename}.bin"
      if [[ ! -f "$BASE/$bin_file" ]]; then
        echo "ERROR: Saved state file not found: $BASE/$bin_file"
        return 1
      fi
      curl -s --request POST \
        --url "http://127.0.0.1:8080/slots/0?action=load" \
        --header "Content-Type: application/json" \
        --data '{ "filename": "'$bin_file'" }'
      ;;

    *)
      echo "Usage: llama {setup|switch {reson|agent|expert|simple}|simple-state|status|start|stop|restart|logs|save <name>|load <name>}"
      ;;
  esac
}

# Run command
llama "$@"
